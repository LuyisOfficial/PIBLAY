:root {
  --bg: #0a192f;
  --card: #112240;
  --primary: #00d4ff;
  --text: #ccd6f6;
}

/* GLOBAL */
body {
  margin: 0;
  font-family: Arial;
  background: var(--bg);
  color: white;
}

/* LAYOUT */
.dashboard {
  display: flex;
  min-height: 100vh;
}

/* SIDEBAR */
.sidebar {
  width: 230px;
  background: #020c1b;
  padding: 20px;
  display: flex;
  flex-direction: column;
}

.sidebar h2 {
  color: var(--primary);
}

.sidebar nav a {
  display: block;
  color: var(--text);
  padding: 12px 0;
  text-decoration: none;
}

.sidebar nav a:hover {
  color: var(--primary);
}

.sidebar button {
  margin-top: auto;
  background: red;
  border: none;
  padding: 10px;
  color: white;
  cursor: pointer;
}

/* MAIN */
.main {
  flex: 1;
  padding: 20px;
}

/* TOPBAR */
.topbar {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20px;
}

/* CARDS */
.stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px,1fr));
  gap: 20px;
}

.card {
  background: var(--card);
  padding: 20px;
  border-radius: 10px;
}

/* TABLE */
.table-section {
  margin-top: 30px;
}

table {
  width: 100%;
  border-collapse: collapse;
}

th, td {
  padding: 12px;
  border-bottom: 1px solid #233554;
}

/* MOBILE */
@media(max-width:768px){
  .sidebar {
    display: none;
  }
}
